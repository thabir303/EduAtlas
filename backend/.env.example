SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local default (sqlite)
DB_ENGINE=sqlite
SQLITE_NAME=db.sqlite3

# Optional local postgres fallback (if DB_ENGINE=postgresql)
DB_NAME=multimedia_edu
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Production (Render) - if set, this overrides DB_ENGINE settings
DATABASE_URL=

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# HTTPS behavior (recommended True in production)
FORCE_HTTPS=False
