SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local default (sqlite)
DB_ENGINE=sqlite
SQLITE_NAME=db.sqlite3

# Optional local postgres fallback (if DB_ENGINE=postgresql)
DB_NAME=multimedia_edu
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Production (Render) - must be a full URL from Render Postgres, e.g. postgresql://...
# Keep it empty locally; do NOT set placeholders like ://
DATABASE_URL=

# Optional: when troubleshooting deploy, keep migrations out of build and run them separately.
RUN_MIGRATIONS_ON_START=False

AUTO_CREATE_ADMIN=False
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# HTTPS behavior (recommended True in production)
FORCE_HTTPS=False

# Set True only if backend should serve /media files directly from local disk.
# For S3/Cloudinary-backed media, set this to False.
SERVE_MEDIA_FILES=True

# Cloudflare R2 (free-plan friendly) media storage
# Set USE_CLOUDFLARE_R2=True in production to upload media to R2.
USE_CLOUDFLARE_R2=False
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev (or your custom domain)
CLOUDFLARE_R2_PUBLIC_BASE_URL=
